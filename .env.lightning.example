# Direct Lightning shell example.
# For Docker, override NEUDEV_WORKSPACE, NEUDEV_SESSION_STORE, and NEUDEV_OLLAMA_HOST at runtime.
NEUDEV_API_KEY=replace-me
NEUDEV_HOST=0.0.0.0
NEUDEV_HTTP_PORT=8765
NEUDEV_WS_PORT=8766
NEUDEV_WORKSPACE=/teamspace/studios/this_studio/neudev-cli
NEUDEV_SESSION_STORE=/teamspace/studios/this_studio/.neudev/hosted_sessions
NEUDEV_OLLAMA_HOST=http://127.0.0.1:11434
NEUDEV_OLLAMA_MODELS=qwen3:latest qwen2.5-coder:7b deepseek-coder-v2:16b starcoder2:7b
NEUDEV_INSTALL_OLLAMA=1
NEUDEV_MODEL=auto
NEUDEV_AGENT_MODE=parallel
NEUDEV_LANGUAGE=English
NEUDEV_BOOTSTRAP=0
NEUDEV_AUTO_PERMISSION=0
NEUDEV_DISABLE_WEBSOCKET=0
NEUDEV_HOSTED_RUN_COMMAND_MODE=restricted
NEUDEV_HOSTED_RUN_COMMAND_ALLOWLIST=
