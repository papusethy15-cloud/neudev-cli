[run]
branch = True
source = neudev
omit =
    */tests/*
    */__pycache__/*
    */.venv/*
    */venv/*
    */site-packages/*
    neudev/observability.py
    neudev/health_check.py

[report]
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    if typing.TYPE_CHECKING:
    @abstractmethod
    @overload

show_missing = True
precision = 2
fail_under = 75.0

[html]
directory = htmlcov

[xml]
output = coverage.xml

[json]
output = coverage.json
